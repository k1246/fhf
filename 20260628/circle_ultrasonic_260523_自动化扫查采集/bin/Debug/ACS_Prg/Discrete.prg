!PNAME=
!PDESC=
ENABLE(X,Y,Z)
REAL positionB1 =0,MovePointB=0
INT GoEnable=0
positionB1 =FPOS(Y) + AnglePosTarget 
IF (positionB1<>FPOS(X) & positionB1 >= 0 & positionB1 < 360)
MovePointB=positionB1
GoEnable=1
ELSE
MovePointB=FPOS(X)
GoEnable=0
END
OUT(0).9=1	!Electromagnet action
if(GoEnable=1)
IF(FPOS(X)<(AnglePosTarget+FPOS(Y)))
JOG X,+	!JOG for a short time
ELSEIF(AnglePosTarget < 0)
JOG X,-
END
WAIT AngleJogDelayTime
PTP/v X,MovePointB,AnglePosSpeed
TILL (MST(X).#MOVE=0)
END
OUT(0).9=0	!Electromagnet action
STOP
